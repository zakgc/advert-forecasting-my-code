{
  "compilerOptions": {
    "paths": {
      "@/*": ["./app/*", "./*", "./config/*", "./lib/*"]
    },
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "resolveJsonModule": true,
    "noErrorTruncation": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
